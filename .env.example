# Core runtime
ENVIRONMENT=development
APP_URL=http://localhost:8000
SECRET_KEY=change-me-32-chars-minimum-please

# Database
DATABASE_URL=postgresql+psycopg://sift:sift@localhost:5432/sift

# LLM scoring
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-flash-1.5

# Email delivery
RESEND_API_KEY=re_...
EMAIL_FROM=Sift <hello@usesift.app>
DRY_RUN_EMAIL=true

# Optional source connectors
TWITTER_BEARER_TOKEN=
YOUTUBE_API_KEY=

# Auth/session settings
MAGIC_LINK_TTL_MINUTES=15
SESSION_TTL_DAYS=30
